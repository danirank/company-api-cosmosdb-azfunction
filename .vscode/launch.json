{
  "version": "0.2.0",
  "configurations": [
    
    
    {
      "name": "Debug API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/Company.Api/bin/Debug/net10.0/Company.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Company.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on: (https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}